{
  "name": "dropspace-api",
  "version": "1.0.0",
  "description": "Dropout Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "npx prisma generate && npx prisma db push",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:migrate": "npx prisma migrate dev",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.2"
  },
  "devDependencies": {
    "prisma": "^6.4.1"
  },
  "engines": {
    "node": ">=18"
  }
}
