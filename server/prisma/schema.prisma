generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String
  password   String
  role       String      @default("user")
  avatar     String?
  savedDrops SavedDrop[]
  comments   Comment[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  logo      String
  website   String?
  drops     Drop[]
  createdAt DateTime @default(now())
}

model Drop {
  id          String      @id @default(cuid())
  title       String
  description String
  imageUrl    String
  price       String
  category    String
  hypeScore   Int         @default(0)
  dropTime    DateTime
  featured    Boolean     @default(false)
  website     String?
  brand       Brand       @relation(fields: [brandId], references: [id])
  brandId     String
  likes       Int         @default(0)
  comments    Comment[]
  saves       SavedDrop[]
  views       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  drop      Drop     @relation(fields: [dropId], references: [id])
  dropId    String
  createdAt DateTime @default(now())
}

model SavedDrop {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  drop   Drop   @relation(fields: [dropId], references: [id])
  dropId String

  @@unique([userId, dropId])
}
